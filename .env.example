# =============================================================================
# NNgo Backend — copy to .env and adjust values
# =============================================================================

APP_NAME=NNgo API
DEBUG=false

# MySQL 8 (asyncmy) — host "mysql" inside Docker Compose
DATABASE_URL=mysql+asyncmy://nngo:nngo_secret@localhost:3306/nngo_db?charset=utf8mb4

# Redis — host "redis" inside Docker Compose
REDIS_URL=redis://localhost:6379/0

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Docker Compose MySQL (must match DATABASE_URL credentials)
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=nngo_db
MYSQL_USER=nngo
MYSQL_PASSWORD=nngo_secret
